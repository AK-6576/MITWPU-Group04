      "messages": [
        {
          "id": "m1",
          "text": "Are you up for a run later?",
          "senderName": "Neighbor",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m2",
          "text": "Yeah, I need to clear my head. Where should we go?",
          "senderName": "Me",
          "isIncoming": false,
          "isHighlighted": false
        },
        {
          "id": "m3",
          "text": "The lake route is nice this time of year, lots of breeze.",
          "senderName": "Neighbor",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m4",
          "text": "True, but the trail is softer on my knees. Can we do the woodland loop?",
          "senderName": "Me",
          "isIncoming": false,
          "isHighlighted": false
        },
        {
          "id": "m5",
          "text": "Fair enough. Woodland loop it is. Meet at the entrance at 6?",
          "senderName": "Neighbor",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m6",
          "text": "Perfect. See you then.",
          "senderName": "Me",
          "isIncoming": false,
          "isHighlighted": false
        }
      ]
    },

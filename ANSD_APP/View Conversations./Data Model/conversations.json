      "end_time": "11:30 PM",
      "category": "friends",
      "icon": "friends_icon",
      "info": true,
      "messages": [
        { "id": "m1", "text": "Bucky Barnes, right? How do you spell your surname?", "senderName": "Me", "isIncoming": false, "isHighlighted": false },
        { "id": "m2", "text": "B-A-R-N-E-S, Sir. From Brooklyn.", "senderName": "Person 1", "isIncoming": true, "isHighlighted": false },
        { "id": "m3", "text": "Nice to meet you, Bucky. Just give me a moment here. I'm looking for the right building.", "senderName": "Me", "isIncoming": false, "isHighlighted": false },
        { "id": "m4", "text": "Yeah, I think it is that one over there. The one with the red paint peeling off.", "senderName": "Me", "isIncoming": false, "isHighlighted": false },
        { "id": "m5", "text": "You want to dropped here then or near the bus stop? I'm not sure which one is closer.", "senderName": "Person 1", "isIncoming": true, "isHighlighted": false },
        { "id": "m6", "text": "The gate would be fine, thanks.", "senderName": "Me", "isIncoming": false, "isHighlighted": false },
        { "id": "m7", "text": "What is the code, Sir?", "senderName": "Person 1", "isIncoming": true, "isHighlighted": false },
        { "id": "m8", "text": "The code is 10042005.", "senderName": "Me", "isIncoming": false, "isHighlighted": false },
        { "id": "m9", "text": "The fare is 120 bucks, Sir. Cash please.", "senderName": "Person 1", "isIncoming": true, "isHighlighted": false },
        { "id": "m10", "text": "120! Jesus, the fare has sky-rocketed a lot!", "senderName": "Me", "isIncoming": false, "isHighlighted": false },
        { "id": "m11", "text": "I know, Sir. But after inflation, this is the best we can do.", "senderName": "Person 1", "isIncoming": true, "isHighlighted": false },
        { "id": "m12", "text": "Public transport would have been cheaper.", "senderName": "Me", "isIncoming": false, "isHighlighted": false }
      ]
    },

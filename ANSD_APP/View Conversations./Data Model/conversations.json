    {
      "id": "1",
      "title": "Scrum Meet",
      "description": "Updates on Project Stardust.",
      "topic_image": "person.3.sequence.fill",
      "notes": "Follow up with Dev team regarding API integration.",
      "participants": [
        {
          "name": "Manager",
          "summary": "Asked about timeline.",
          "image": "avatar_2"
        },
        {
          "name": "Me",
          "summary": "Confirmed Stardust phase 1 is complete.",
          "image": "avatar_1"
        },
        {
          "name": "Sarah (Dev)",
          "summary": "Raised concern about database latency.",
          "image": "avatar_3"
        }
      ],
      "date": "4 Oct 2025",
      "cal": "2025-10-15T09:30:00Z",
      "start_time": "09:30 AM",
      "end_time": "10:00 AM",
      "category": "office",
      "icon": "briefcase.fill",
      "info": true,
      "messages": [
        {
          "id": "m1",
          "text": "Good morning everyone. Let's start with the Project Stardust demo. Are we set?",
          "senderName": "Manager",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m2",
          "text": "Yes, phase 1 is deployed. I'll present the UI updates. The new dashboard is live on staging.",
          "senderName": "Me",
          "isIncoming": false,
          "isHighlighted": false
        },
        {
          "id": "m3",
          "text": "Excellent. It looks much cleaner than the old version. How are the load times?",
          "senderName": "Manager",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m4",
          "text": "We are seeing a slight latency spike when fetching the user history.",
          "senderName": "Sarah (Dev)",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m5",
          "text": "Is it critical?",
          "senderName": "Manager",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m6",
          "text": "It adds about 200ms. I can optimize the query by tomorrow.",
          "senderName": "Sarah (Dev)",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m7",
          "text": "Sounds like a plan. Let's aim to have that fixed before the client demo on Friday.",
          "senderName": "Manager",
          "isIncoming": true,
          "isHighlighted": false
        },
        {
          "id": "m8",
          "text": "Will do. I'll coordinate with the backend team.",
          "senderName": "Me",
          "isIncoming": false,
          "isHighlighted": false
        }
      ]
    },
